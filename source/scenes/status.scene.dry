    Q.jse_strength_2 = Q.jse_strength.toFixed(1);
}
if (Q.bs_strength) {
    Q.bs_strength_2 = Q.bs_strength.toFixed(1);
}
if (Q.jsu_strength) {
    Q.jsu_strength_2 = Q.jsu_strength.toFixed(1);
}
!}

